{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 52428800
  },
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "parsableStyle": false,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "removeComments": false,
    "removeEmptyLines": true,
    "compress": false,
    "topFilesLength": 5,
    "showLineNumbers": false,
    "truncateBase64": true,
    "copyToClipboard": false,
    "includeFullDirectoryStructure": true,
    "tokenCountTree": false
  },
  "include": [],
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      ".claude/**/*",
      ".vscode/**/*",
      "config/**/*",
      "**/dist/**",
      "mock/**/*",
      "**/node_modules/**",
      "openspec/**/*",
      "public/**/*",
      "src/assets/**/*",
      "CLAUDE.md",
      "README.md",
      "repomix.config.ts"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
